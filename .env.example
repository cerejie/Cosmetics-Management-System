# Project Settings -> API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Do NOT put the service_role key or the JWT secret here. Anything prefixed with
# VITE_ is bundled into the browser build and is readable by anyone using the
# app. The JWT secret is stored in app.settings inside the database, and is set
# once by hand after applying migration 0004.
