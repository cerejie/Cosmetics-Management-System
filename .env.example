# Project Settings -> API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Do NOT put the service_role key here. Anything prefixed with VITE_ is bundled
# into the browser build and is readable by anyone using the app. Account
# creation uses the service_role key inside the create-user Edge Function,
# where Supabase injects it automatically.
